# Auto-detect text files and normalize line endings to LF on checkout
* text=auto eol=lf

# Explicitly declare text files
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Binary files — do not touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.svg  text eol=lf

# Lock files — diff as text, don't merge
package-lock.json merge=ours
